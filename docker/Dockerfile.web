FROM node:20-alpine AS builder
WORKDIR /app
# python3/make/g++ нужны для нативной компиляции bcrypt из workspace apps/api,
# когда prebuilt-бинарник не качается. Без них `npm install` на root-уровне
# падает с node-pre-gyp ERR (см. fail run #25439732478). Эти пакеты живут
# только в throwaway-builder-stage — итоговый web-образ остаётся компактным.
RUN apk add --no-cache python3 make g++
COPY . .
RUN npm install
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build --workspace=apps/web 2>/dev/null || (cd apps/web && npx next build)

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
# В standalone-режиме public/ НЕ копируется автоматически — нужно отдельно.
# Без этой строки stmichael-logo.png, sw.js и другие статики из public/
# отдают 404. См. https://nextjs.org/docs/app/api-reference/next-config-js/output#caveats
COPY --from=builder /app/apps/web/public ./apps/web/public
RUN chown -R nextjs:nodejs /app
USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "apps/web/server.js"]
